{
  "$defs": {
    "artifact": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "locality": {
                "enum": [
                  "local-only",
                  "upload-eligible"
                ],
                "type": "string"
              }
            },
            "required": [
              "locality"
            ]
          },
          "then": {
            "properties": {
              "locator": {
                "maxLength": 2048,
                "pattern": "^local-resource://[A-Za-z0-9][A-Za-z0-9._-]{0,127}/[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
                "type": "string"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "locality": {
                "enum": [
                  "hosted"
                ],
                "type": "string"
              }
            },
            "required": [
              "locality"
            ]
          },
          "then": {
            "properties": {
              "locator": {
                "maxLength": 2048,
                "pattern": "^artifact://[A-Za-z0-9][A-Za-z0-9._-]{0,127}/[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
                "type": "string"
              }
            }
          }
        }
      ],
      "properties": {
        "artifact_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "classification": {
          "enum": [
            "public",
            "metadata",
            "internal",
            "confidential",
            "restricted"
          ],
          "type": "string"
        },
        "creator_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "creator_type": {
          "enum": [
            "agent",
            "human",
            "workflow",
            "system"
          ],
          "type": "string"
        },
        "digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "extensions": {
          "additionalProperties": true,
          "maxProperties": 64,
          "propertyNames": {
            "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+/[a-z][a-z0-9._-]{0,63}$"
          },
          "type": "object"
        },
        "locality": {
          "enum": [
            "local-only",
            "upload-eligible",
            "hosted"
          ],
          "type": "string"
        },
        "locator": {
          "oneOf": [
            {
              "maxLength": 2048,
              "pattern": "^local-resource://[A-Za-z0-9][A-Za-z0-9._-]{0,127}/[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            },
            {
              "maxLength": 2048,
              "pattern": "^artifact://[A-Za-z0-9][A-Za-z0-9._-]{0,127}/[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
              "type": "string"
            }
          ]
        },
        "mime_type": {
          "maxLength": 256,
          "minLength": 1,
          "type": "string"
        },
        "protocol_version": {
          "const": "mission-control.provider.v1alpha1"
        },
        "review_state": {
          "enum": [
            "pending",
            "approved",
            "rejected"
          ],
          "type": "string"
        },
        "session_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "size": {
          "minimum": 0,
          "type": "integer"
        },
        "source_resources": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
            "type": "string"
          },
          "maxItems": 256,
          "minItems": 0,
          "type": "array",
          "uniqueItems": true
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n\\t ]+$",
          "type": "string"
        }
      },
      "required": [
        "protocol_version",
        "artifact_id",
        "session_id",
        "creator_type",
        "creator_id",
        "version",
        "review_state",
        "locality",
        "locator",
        "mime_type",
        "size",
        "digest",
        "classification",
        "source_resources",
        "extensions"
      ],
      "type": "object"
    },
    "context_receipt": {
      "additionalProperties": false,
      "properties": {
        "context_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "delivered_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "delivery_mode": {
          "enum": [
            "initial_prompt",
            "system_instructions",
            "mounted_file",
            "environment_reference",
            "mcp_resource",
            "acp_initialization",
            "project_instructions",
            "follow_up_message"
          ],
          "type": "string"
        },
        "native_runtime_may_ignore": {
          "type": "boolean"
        },
        "native_session_id": {
          "maxLength": 1024,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n]+$",
          "type": "string"
        },
        "protocol_version": {
          "const": "mission-control.provider.v1alpha1"
        },
        "provider_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "session_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "source_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "status": {
          "enum": [
            "accepted",
            "rejected",
            "failed"
          ],
          "type": "string"
        }
      },
      "required": [
        "protocol_version",
        "session_id",
        "provider_id",
        "native_session_id",
        "context_version",
        "source_digest",
        "delivery_mode",
        "delivered_at",
        "status",
        "native_runtime_may_ignore"
      ],
      "type": "object"
    },
    "provider_binding": {
      "additionalProperties": false,
      "properties": {
        "artifact_digest": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "native_id": {
          "maxLength": 1024,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n]+$",
          "type": "string"
        },
        "native_resume_reference": {
          "maxLength": 1024,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n]+$",
          "type": "string"
        },
        "provider_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "type": "string"
        },
        "provider_version": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n\\t ]+$",
          "type": "string"
        }
      },
      "required": [
        "provider_id",
        "provider_version",
        "native_id",
        "artifact_digest"
      ],
      "type": "object"
    }
  },
  "$id": "urn:gocodealone:mission-control:session:v1alpha1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "activity": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "enum": [
            "authoritative",
            "inferred"
          ],
          "type": "string"
        },
        "axis": {
          "const": "activity"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "expires_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "sequence": {
          "minimum": 1,
          "type": "integer"
        },
        "source": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n]+$",
          "type": "string"
        },
        "state": {
          "enum": [
            "idle",
            "working",
            "waiting_for_user",
            "waiting_for_approval",
            "blocked",
            "done",
            "failed",
            "unknown"
          ],
          "type": "string"
        },
        "status": {
          "maxLength": 1024,
          "minLength": 0,
          "type": "string"
        }
      },
      "required": [
        "axis",
        "state",
        "source",
        "observed_at",
        "sequence",
        "confidence",
        "authority"
      ],
      "type": "object"
    },
    "context_version": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "environment": {
      "$ref": "#/$defs/provider_binding"
    },
    "extensions": {
      "additionalProperties": true,
      "maxProperties": 64,
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+/[a-z][a-z0-9._-]{0,63}$"
      },
      "type": "object"
    },
    "gateway_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    },
    "harness": {
      "$ref": "#/$defs/provider_binding"
    },
    "health": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "enum": [
            "authoritative",
            "inferred"
          ],
          "type": "string"
        },
        "axis": {
          "const": "health"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "expires_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "sequence": {
          "minimum": 1,
          "type": "integer"
        },
        "source": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n]+$",
          "type": "string"
        },
        "state": {
          "enum": [
            "healthy",
            "degraded",
            "unreachable",
            "unknown"
          ],
          "type": "string"
        },
        "status": {
          "maxLength": 1024,
          "minLength": 0,
          "type": "string"
        }
      },
      "required": [
        "axis",
        "state",
        "source",
        "observed_at",
        "sequence",
        "confidence",
        "authority"
      ],
      "type": "object"
    },
    "lifecycle": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "enum": [
            "authoritative",
            "inferred"
          ],
          "type": "string"
        },
        "axis": {
          "const": "lifecycle"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        "expires_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "pattern": "Z$",
          "type": "string"
        },
        "sequence": {
          "minimum": 1,
          "type": "integer"
        },
        "source": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[^\\x00\\r\\n]+$",
          "type": "string"
        },
        "state": {
          "enum": [
            "provisioning",
            "starting",
            "running",
            "stopped",
            "terminated",
            "archived",
            "disconnected",
            "unknown"
          ],
          "type": "string"
        },
        "status": {
          "maxLength": 1024,
          "minLength": 0,
          "type": "string"
        }
      },
      "required": [
        "axis",
        "state",
        "source",
        "observed_at",
        "sequence",
        "confidence",
        "authority"
      ],
      "type": "object"
    },
    "protocol_version": {
      "const": "mission-control.provider.v1alpha1"
    },
    "runtime": {
      "$ref": "#/$defs/provider_binding"
    },
    "session_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
      "type": "string"
    }
  },
  "required": [
    "protocol_version",
    "session_id",
    "gateway_id",
    "environment",
    "harness",
    "lifecycle",
    "activity",
    "health",
    "context_version",
    "extensions"
  ],
  "title": "Mission Control canonical session v1alpha1",
  "type": "object"
}
